{
  "expo": {
    "name": "DevSnippets AI",
    "slug": "devsnippets-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "devsnippets",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devsnippets.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F97316",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.devsnippets.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-file-system"
    ]
  }
}
